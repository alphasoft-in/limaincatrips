---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.tsx';
---

<Layout title="Tours en Lima - Lima Inka Trip">
	<Navbar client:load solid={true} currentPath=`/lima` />
	<main class="pt-24 min-h-screen bg-gray-50">
		<section class="py-12">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
				<span class="text-brand-accent font-bold tracking-wider uppercase text-sm">Destino Lima</span>
				<h1 class="mt-2 text-4xl font-display font-bold text-brand-primary mb-6">Paquetes Turísticos en Lima y Callao</h1>
				<p class="text-gray-600 max-w-2xl mx-auto">Conoce la Ciudad de los Reyes, su historia colonial y la belleza de la fauna marina en el Callao.</p>
			</div>

			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{/* Tour Card Islas Palomino */}
					<a href="/lima/islas-palomino" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="https://images.unsplash.com/photo-1596700512604-bb703b688c22?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
								alt="Islas Palomino, Lobos Marinos" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full">
								Medio Día
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Callao
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Islas Palomino</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Naturaleza y fauna marina. Una increíble travesía en yate con la oportunidad de nadar con lobos marinos.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card Lima y Miraflores City Tour */}
					<a href="/lima/lima-miraflores-city-tour" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="https://images.unsplash.com/photo-1577587230708-187fdbef4d91?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
								alt="Centro Histórico de Lima" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full">
								Medio Día
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Lima - Miraflores
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">City Tour Lima y Miraflores</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Descubre la Ciudad de los Reyes. Visita el centro histórico, las Catacumbas y degusta nuestro Pisco Sour.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>








					
					
					

				</div>
			</div>
		</section>
	</main>
</Layout>
