---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.tsx';
import BookingWidget from '../../components/BookingWidget.tsx';

export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return tours.map((tour: CollectionEntry<'tours'>) => ({
    // @ts-ignore - destination is dynamically added to frontmatter
    params: { destination: tour.data.destination || 'tours', slug: tour.id },
    props: { tour },
  }));
}

type Props = {
  tour: CollectionEntry<'tours'>;
};

const { tour } = Astro.props;
const { Content } = await render(tour);
const data = tour.data;

const whatsappLink = `https://wa.me/51936976776?text=${encodeURIComponent(data.whatsappText || `Hola, quisiera información sobre el tour ${data.title}`)}`;
---

<Layout title={data.metaTitle || `${data.title} - Lima Inca Trips`}>
	<Navbar client:load solid={true} currentPath={Astro.url.pathname} />
	
	<main class="min-h-screen bg-brand-light">
		{/* Hero Section */}
		<div class="relative h-[60vh] bg-brand-primary overflow-hidden">
			<img 
				src={data.heroImage} 
				alt={data.title} 
				class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
			<div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 pt-24">
				<span class="text-brand-secondary font-bold tracking-widest uppercase text-lg mb-4 block drop-shadow-lg">{data.subtitle}</span>
				<h1 class="text-4xl md:text-5xl lg:text-6xl text-center font-display font-bold text-white mb-6 drop-shadow-xl max-w-4xl">{data.title}</h1>
				<div class="inline-block px-6 py-2 bg-brand-secondary text-white rounded-full font-bold text-xl shadow-lg">
					{data.badges[0]}
				</div>
			</div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
				
				{/* Itinerary Column */}
				<div class="lg:col-span-2">
					<div class="flex items-center gap-3 mb-8">
						<svg class="w-8 h-8 text-brand-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
						<h2 class="text-4xl font-display font-bold text-brand-primary">Itinerario del Viaje</h2>
					</div>
					
					<div class="mb-10 itinerary-wrapper">
						<Content />
					</div>

				</div>

				{/* Info Column */}
				<div class="lg:col-span-1 space-y-8">
					
          {data.includes.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-brand-primary p-6">
                <h3 class="text-2xl font-display font-bold text-white flex items-center gap-2">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  Incluye
                </h3>
              </div>
              <div class="p-6">
                <ul class="space-y-3 text-sm text-gray-700">
                  {data.includes.map((item: string) => (
                    <li class="flex items-start gap-2">
                      <span class="text-brand-secondary font-bold">•</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

          {data.excludes.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-gray-100 p-6">
                <h3 class="text-2xl font-display font-bold text-gray-800 flex items-center gap-2">
                  <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  No Incluye
                </h3>
              </div>
              <div class="p-6">
                <ul class="space-y-3 text-sm text-gray-600">
                  {data.excludes.map((item: string) => (
                    <li class="flex items-start gap-2">
                      <span class="text-gray-400 font-bold">•</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

					{/* Pick Up Locations */}
          {data.pickupInfo && data.pickupInfo.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mt-8">
              {data.pickupInfo.map((infoBlock: { title: string; times: { time: string; description: string }[] }) => (
                <div class="bg-blue-50 p-6 border-b border-blue-100 last:border-b-0">
                  <h3 class="font-bold text-blue-900 mb-4">{infoBlock.title}</h3>
                  {infoBlock.times.map((timeBlock: { time: string; description: string }) => (
                    <div class="mb-4 last:mb-0">
                      <ul class="space-y-1 text-sm text-blue-700">
                        <li><span class="font-bold">{timeBlock.time}</span> {timeBlock.description}</li>
                      </ul>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          )}

					<div class="mt-8">
						<BookingWidget client:load tourTitle={data.title} />
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style is:global>
  /* Evita que la línea de tiempo roja se pase del último día y cree un espacio engañoso */
  .itinerary-wrapper .border-l-4 > div:last-child {
    margin-bottom: 0 !important;
  }
</style>
