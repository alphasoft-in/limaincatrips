---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.tsx';
---

<Layout title="Contacto | Lima Inca Trips" lang="en">
	<Navbar client:load solid={true} currentPath={Astro.url.pathname} lang="en" />
	<main class="pt-24 min-h-screen">
		<section class="py-24 bg-white">
			<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<span class="text-brand-accent font-bold tracking-wider uppercase text-sm">Contáctanos</span>
				<h1 class="mt-2 text-3xl md:text-4xl font-display font-bold text-brand-primary mb-6">Ponte en Contacto</h1>
				<p class="text-gray-600 mb-12">
					¿Listo para tu próxima aventura? ¿Tienes alguna duda sobre nuestros tours? Llena el formulario o contáctanos directamente.
				</p>
				
				<div class="bg-brand-light p-8 rounded-2xl shadow-lg text-left">
					<form class="space-y-6">
						<div>
							<label for="name" class="block text-sm font-medium text-gray-700">Nombre Completo</label>
							<input type="text" id="name" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary p-3" />
						</div>
						<div>
							<label for="email" class="block text-sm font-medium text-gray-700">Correo Electrónico</label>
							<input type="email" id="email" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary p-3" />
						</div>
						<div>
							<label for="message" class="block text-sm font-medium text-gray-700">Mensaje</label>
							<textarea id="message" rows="4" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary p-3"></textarea>
						</div>
						<button type="submit" class="w-full bg-brand-primary text-white font-bold py-3 px-4 rounded-full hover:bg-brand-dark transition-colors">
							Enviar Mensaje
						</button>
					</form>
				</div>
			</div>
		</section>
	</main>
</Layout>
