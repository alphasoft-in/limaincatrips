---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.tsx';
---

<Layout title="Tours in Cusco - Lima Inca Trips" lang="en">
	<Navbar client:load solid={true} currentPath="/en/cusco" lang="en" />
	<main class="pt-24 min-h-screen bg-gray-50">
		<section class="py-12">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
				<span class="text-brand-accent font-bold tracking-wider uppercase text-sm">Destino Imperial</span>
				<h1 class="mt-2 text-4xl font-display font-bold text-brand-primary mb-6">Tour Packages in Cusco</h1>
				<p class="text-gray-600 max-w-2xl mx-auto">Discover the magic of the navel of the world, the mystery of Machu Picchu, and the Inca heritage in our carefully designed packages.</p>
			</div>

			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					
					{/* Tour Card 6D/5N Mystical Cusco */}
					<a href="/en/cusco/cusco-mistico-6d-5n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/cusco/cusco6d5n.png" 
								alt="Mystical Cusco 6D 5N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								6D / 5N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Complete Package
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Mystical Cusco</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">A deep experience through the sacred corners of the Inca Empire, including the Sacred Valley, Machu Picchu, and natural wonders.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>
					
					{/* Tour Card 5D/4N Magical Cusco */}
					<a href="/en/cusco/cusco-magico-5d-4n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/cusco/cusco5d4n.png" 
								alt="Magical Cusco 5D 4N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								5D / 4N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Featured Package
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Magical Cusco</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">The perfect balance to get to know the magic of the city of Cusco, tour the impressive Sacred Valley and conquer Machu Picchu.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card 4D/3N Traditional Cusco */}
					<a href="/en/cusco/cusco-tradicional-4d-3n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/cusco/cusco4d3n.png" 
								alt="Traditional Cusco 4D 3N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								4D / 3N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Classic Package
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Traditional Cusco</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Ideal for those with limited time but do not want to miss the most iconic places: City Tour, Sacred Valley, and Machu Picchu.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

				</div>
			</div>
		</section>
	</main>
</Layout>
