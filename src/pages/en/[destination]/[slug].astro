---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.tsx';
import BookingWidget from '../../../components/BookingWidget.tsx';

export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return tours.map((tour: CollectionEntry<'tours'>) => ({
    // @ts-ignore - destination is dynamically added to frontmatter
    params: { destination: tour.data.destination || 'tours', slug: tour.id },
    props: { tour },
  }));
}

type Props = {
  tour: CollectionEntry<'tours'>;
};

const { tour } = Astro.props;
const { Content } = await render(tour);
const data = tour.data;

const allTours = await getCollection('tours');
const relatedTours = allTours
  .filter((t: CollectionEntry<'tours'>) => t.data.destination === data.destination && t.id !== tour.id)
  .slice(0, 3);

const whatsappLink = `https://wa.me/51936976776?text=${encodeURIComponent(data.whatsappText || `Hola, quisiera información sobre el tour ${data.title}`)}`;
---

<Layout title={data.metaTitle || `${data.title} - Lima Inca Trips`}>
	<Navbar client:load solid={true} currentPath={Astro.url.pathname} lang="en" />
	
	<main class="min-h-screen bg-brand-light">
		{/* Hero Section */}
		<div class="relative h-[60vh] bg-black overflow-hidden">
			<img 
				src={data.heroImage} 
				alt={data.title} 
				class="absolute inset-0 w-full h-full object-cover opacity-75"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
			<div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 pt-24">
				<span class="text-brand-secondary font-bold tracking-widest uppercase text-lg mb-4 block drop-shadow-lg">{data.subtitle}</span>
				<h1 class="text-4xl md:text-5xl lg:text-6xl text-center font-display font-bold text-white mb-6 drop-shadow-xl max-w-4xl">{data.title}</h1>
				<div class="inline-block px-6 py-2 bg-brand-secondary text-white rounded-full font-bold text-xl shadow-lg">
					{data.badges[0]}
				</div>
			</div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
				
				{/* Itinerary Column */}
				<div class="lg:col-span-2">
					<div class="flex items-center gap-3 mb-8">
						<svg class="w-8 h-8 text-brand-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
						<h2 class="text-4xl font-display font-bold text-brand-primary">Itinerario del Viaje</h2>
					</div>
					
					<div class="mb-10 itinerary-wrapper">
						<Content />
					</div>

          {data.recommendations && data.recommendations.length > 0 && (
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-10 p-6">
              <h3 class="text-xl font-bold text-gray-900 flex items-center gap-2 mb-4">
                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                ¿Qué traer? (Recomendado)
              </h3>
              
              <ul class="space-y-3 text-gray-700 text-[15px]">
                {data.recommendations.map((item: string) => (
                  <li class="flex items-start gap-2">
                    <span class="text-brand-primary font-bold mt-[2px]">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              
              {data.note && (
                <div class="mt-6 bg-[#f0f4f8] text-[#1e3a8a] p-4 rounded-xl text-sm">
                  <span class="font-bold">Nota:</span> 
                  {data.note.replace('Nota: ', '').split('aquí').length > 1 ? (
                    <>
                      {data.note.replace('Nota: ', '').split('aquí')[0]}
                      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="font-bold underline hover:text-brand-primary">aquí</a>
                      {data.note.replace('Nota: ', '').split('aquí')[1]}
                    </>
                  ) : (
                    data.note.replace('Nota: ', '')
                  )}
                </div>
              )}
            </div>
          )}

				</div>

				{/* Info Column */}
				<div class="lg:col-span-1 space-y-8">
					
          {data.includes.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-brand-primary p-6">
                <h3 class="text-2xl font-display font-bold text-white flex items-center gap-2">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  Incluye
                </h3>
              </div>
              <div class="p-6">
                <ul class="space-y-3 text-sm text-gray-700">
                  {data.includes.map((item: string) => (
                    <li class="flex items-start gap-2">
                      <span class="text-brand-secondary font-bold">•</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

          {data.excludes.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-gray-100 p-6">
                <h3 class="text-2xl font-display font-bold text-gray-800 flex items-center gap-2">
                  <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  No Incluye
                </h3>
              </div>
              <div class="p-6">
                <ul class="space-y-3 text-sm text-gray-600">
                  {data.excludes.map((item: string) => (
                    <li class="flex items-start gap-2">
                      <span class="text-gray-400 font-bold">•</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

          {data.conditions && data.conditions.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mt-8">
              <div class="bg-brand-secondary p-6">
                <h3 class="text-xl font-display font-bold text-white flex items-center gap-2">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                  Condiciones y vigencia
                </h3>
              </div>
              <div class="p-6">
                <ul class="space-y-3 text-sm text-gray-600">
                  {data.conditions.map((item: string) => (
                    <li class="flex items-start gap-2">
                      <span class="text-brand-secondary font-bold">•</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

					{/* Pick Up Locations */}
          {data.pickupInfo && data.pickupInfo.length > 0 && (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mt-8">
              {data.pickupInfo.map((infoBlock: { title: string; times: { time: string; description: string }[] }) => (
                <div class="bg-blue-50 p-6 border-b border-blue-100 last:border-b-0">
                  <h3 class="font-bold text-blue-900 mb-4">{infoBlock.title}</h3>
                  {infoBlock.times.map((timeBlock: { time: string; description: string }) => (
                    <div class="mb-4 last:mb-0">
                      <ul class="space-y-1 text-sm text-blue-700">
                        <li><span class="font-bold">{timeBlock.time}</span> {timeBlock.description}</li>
                      </ul>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          )}

					<div class="mt-8">
						<BookingWidget client:load tourTitle={data.title} />
					</div>

          {/* Recommended Tours */}
          {relatedTours.length > 0 && (
            <div class="mt-8 bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-gray-50 p-6 border-b border-gray-100">
                <h3 class="text-xl font-display font-bold text-gray-800">Tours Recomendados</h3>
              </div>
              <div class="divide-y divide-gray-100">
                {relatedTours.map((relatedTour: CollectionEntry<'tours'>) => (
                  <a href={`/en/${relatedTour.data.destination || 'tours'}/${relatedTour.id}`} class="flex gap-4 p-4 hover:bg-gray-50 transition-colors">
                    <img src={relatedTour.data.heroImage} alt={relatedTour.data.title} class="w-20 h-20 object-cover rounded-lg flex-shrink-0" />
                    <div>
                      <h4 class="font-bold text-brand-primary text-sm line-clamp-2">{relatedTour.data.title}</h4>
                      <span class="text-xs text-gray-500 mt-1 block">{relatedTour.data.badges?.[0] || 'Tour'}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
				</div>
			</div>
		</div>
	</main>
</Layout>

<style is:global>
  /* Evita que la línea de tiempo roja se pase del último día y cree un espacio engañoso */
  .itinerary-wrapper .border-l-4 > div:last-child {
    margin-bottom: 0 !important;
  }
</style>
