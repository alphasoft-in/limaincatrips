---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.tsx';
---

<Layout title="Tours en Pacaya Samiria - Lima Inca Trips" lang="en">
	<Navbar client:load solid={true} currentPath=`/pacaya-samiria` lang="en" />
	<main class="pt-24 min-h-screen bg-gray-50">
		<section class="py-12">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
				<span class="text-brand-accent font-bold tracking-wider uppercase text-sm">Destino Selva</span>
				<h1 class="mt-2 text-4xl font-display font-bold text-brand-primary mb-6">Reserva Nacional Pacaya Samiria</h1>
				<p class="text-gray-600 max-w-2xl mx-auto">Sumérgete en la "Selva de los Espejos" y descubre una de las áreas protegidas más ricas y fascinantes del mundo.</p>
			</div>

			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					
					{/* Tour Card 8D 7N */}
					<a href="/pacaya-samiria/pacaya-samiria-8d-7n-desde-tarapoto" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="https://images.unsplash.com/photo-1542317826-646700c926f0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
								alt="Pacaya Samiria 8D 7N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								8D / 7N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Desde Tarapoto
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Tours Pacaya Samiria desde Tarapoto</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Una expedición inolvidable iniciando en Tarapoto y adentrándose en el corazón de la Reserva Nacional Pacaya Samiria.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>
					
					{/* Tour Card 6D 5N */}
					<a href="/pacaya-samiria/pacaya-samiria-6d-5n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="https://images.unsplash.com/photo-1615886745167-27b99d54e4f5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
								alt="Pacaya Samiria 6D 5N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								6D / 5N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Reserva Nacional
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Tours Reserva Nacional Pacaya Samiria</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Seis días explorando la selva de los espejos. Observación de delfines rosados, caimanes y la biodiversidad más espectacular de la cuenca amazónica.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card 3D 2N */}
					<a href="/pacaya-samiria/pacaya-samiria-3d-2n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="https://images.unsplash.com/photo-1577700203590-7fbf295321f8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
								alt="Pacaya Samiria 3D 2N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								3D / 2N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Reserva Nacional
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Tours Reserva Nacional Pacaya Samiria</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Una escapada rápida pero intensa para quienes tienen el tiempo medido pero quieren experimentar la majestuosidad de la selva virgen.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card 13D 12N */}
					<a href="/pacaya-samiria/pacaya-samiria-13d-12n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="https://images.unsplash.com/photo-1518182170546-076616fd4aa6?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
								alt="Pacaya Samiria 13D 12N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								13D / 12N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Gran Expedición
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Tours Reserva Nacional Pacaya Samiria</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">El viaje definitivo. Casi dos semanas navegando profundamente en Pacaya Samiria, visitando comunidades remotas y acampando en la selva profunda.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

				</div>
			</div>
		</section>
	</main>
</Layout>
