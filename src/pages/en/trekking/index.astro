---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.tsx';
---

<Layout title="Trekking Tours - Lima Inca Trips" lang="en">
	<Navbar client:load solid={true} currentPath="/en/trekking" lang="en" />
	<main class="pt-24 min-h-screen bg-gray-50">
		<section class="py-12">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
				<span class="text-brand-accent font-bold tracking-wider uppercase text-sm">Adventure and Nature</span>
				<h1 class="mt-2 text-4xl font-display font-bold text-brand-primary mb-6">Trekking Packages</h1>
				<p class="text-gray-600 max-w-2xl mx-auto">Explore the best hiking routes, Andean landscapes, and mountain jungle with our specialized tours.</p>
			</div>

			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

					{/* Tour Card Trekking Chachapoyas 4D 3N */}
					<a href="/en/trekking/trekking-chachapoyas-4d-3n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/trekking/teleferico.png" 
								alt="Trekking Chachapoyas 4D 3N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								4D / 3N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Amazonas Trekking
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Viewpoints Route 4D / 3N</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">A walking adventure discovering the hidden treasures of Chachapoyas, incredible landscapes, and majestic waterfalls.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card Trekking Museo de Momias 4D 3N */}
					<a href="/en/trekking/trekking-museo-momias-4d-3n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/trekking/museo_de_las_momias.png" 
								alt="Museo de Momias 4D 3N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								4D / 3N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Amazonas Trekking
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Mummies Museum 4D / 3N</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Explore the fascinating Leymebamba Mummy Museum and embark on a unique trek.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card Trekking Laguna de los Condores */}
					<a href="/en/trekking/trekking-laguna-de-los-condores" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/trekking/laguna_de_los_condores.png" 
								alt="Laguna de los Cóndores" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								3D / 2N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Amazonas Trekking
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Condors Lagoon 3D / 2N</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">An extreme expedition to the enigmatic Lagoon of the Mummies, deep in the cloud forest.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card Trekking Gran Vilaya */}
					<a href="/en/trekking/trekking-gran-vilaya-4d-3n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/trekking/gran_vilaya.png" 
								alt="Gran Vilaya 4D / 3N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								4D / 3N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Amazonas Trekking
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Gran Vilaya 4D / 3N</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Una espectacular ruta que combina sitios arqueológicos como Pueblo de los Muertos, Karajía, Gran Vilaya y Kuelap.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

					{/* Tour Card Trekking Gran Vilaya 3D 2N */}
					<a href="/en/trekking/trekking-gran-vilaya-3d-2n" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
						<div class="relative h-64 overflow-hidden">
							<img 
								src="/trekking/gran_vilaya3d.png" 
								alt="Gran Vilaya 3D / 2N" 
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
							/>
							<div class="absolute top-4 right-4 bg-brand-secondary text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
								3D / 2N
							</div>
						</div>
						<div class="p-6 flex-1 flex flex-col">
							<div class="flex items-center text-brand-accent text-xs font-semibold uppercase tracking-wider mb-2">
								<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								Amazonas Trekking
							</div>
							<h3 class="text-xl font-display font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors">Gran Vilaya 3D / 2N</h3>
							<p class="text-gray-600 text-sm mb-4 line-clamp-3">Una aventura express de senderismo por la Amazonía Andina recorriendo el Valle de Belén y la fortaleza de Kuelap.</p>
							
							<div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-end">
								<span class="text-brand-secondary font-bold hover:underline flex items-center">
									View details
									<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</div>
					</a>

				</div>
			</div>
		</section>
	</main>
</Layout>
