---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.tsx';
---

<Layout title="Full Day Paracas and Huacachina - Lima Inca Trips">
	<Navbar client:load solid={true} currentPath={Astro.url.pathname} />
	
	<main class="min-h-screen bg-brand-light">
		{/* Hero Section */}
		<div class="relative h-[60vh] bg-brand-primary overflow-hidden">
			<img 
				src="https://images.unsplash.com/photo-1596700512604-bb703b688c22?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" 
				alt="Paracas and Huacachina" 
				class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
			<div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 pt-24">
				<span class="text-brand-secondary font-bold tracking-widest uppercase text-lg mb-4 block drop-shadow-lg">Desert and Ocean Adventure</span>
				<h1 class="text-4xl md:text-5xl lg:text-6xl text-center font-display font-bold text-white mb-6 drop-shadow-xl max-w-4xl">Paracas & Huacachina</h1>
				<div class="inline-block px-6 py-2 bg-brand-secondary text-white rounded-full font-bold text-xl shadow-lg">
					Full Day </div>
			</div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
				
				{/* Itinerary Column */}
				<div class="lg:col-span-2">
					<div class="flex items-center gap-3 mb-8">
						<svg class="w-8 h-8 text-brand-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
						<h2 class="text-4xl font-display font-bold text-brand-primary">Tour Itinerary</h2>
					</div>
					
					<div class="mb-16">
						<div class="relative border-l-4 border-brand-secondary pl-8 ml-4">
							<div class="mb-10 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
								
								<h4 class="text-lg font-bold text-brand-accent mb-2">MORNING: LIMA TO PARACAS</h4>
								<p class="text-gray-600 leading-relaxed mb-4">
									Pick-up from the indicated location in Lima and transfer to Paracas.
								</p>

								<h4 class="text-lg font-bold text-brand-accent mb-2">BALLESTAS ISLANDS</h4>
								<p class="text-gray-600 leading-relaxed mb-4">
									We begin the tour by visiting the BALLESTAS ISLANDS, on a 1 hour and 30-minute excursion, where we will visit the Paracas Reserve and appreciate the marine flora and fauna, as well as the famous Candelabro geoglyph. Then we will taste the typical sweets of Paracas: chocotejas, cookies, tejas, among others.
								</p>

								<h4 class="text-lg font-bold text-brand-accent mb-2">WINE TASTING IN ICA</h4>
								<p class="text-gray-600 leading-relaxed mb-4">
									We arrive at the estate in Ica where we will have a WINE TASTING. To the rhythm of poems, we will taste the best wines, piscos, and creams from Ica. We will enjoy the atmosphere of the wine winery and have time for photos, lunch, and shopping.
								</p>

								<h4 class="text-lg font-bold text-brand-accent mb-2">HUACACHINA OASIS</h4>
								<p class="text-gray-600 leading-relaxed mb-4">
									We continue the tour and arrive at Huacachina, one of the most entertaining attractions in the southern area. You will discover an oasis in the middle of the desert, with a magnificent legend of mermaids.
								</p>

								<h4 class="text-lg font-bold text-brand-accent mb-2">DUNE BUGGIES & SANDBOARDING</h4>
								<p class="text-gray-600 leading-relaxed mb-4">
									We will board the dune buggies, also known as sand cars, where for approximately 45 minutes you will fully enjoy an extraordinary adventure riding through the desert dunes and sliding down on sandboards.
								</p>
								
								<div class="border-t border-gray-100 pt-4 mt-4">
									<ul class="space-y-2 text-sm text-gray-600 font-semibold">
										<li class="flex justify-between"><span>04:15 PM Approx.</span> <span>Departure from Huacachina and return to Lima.</span></li>
										<li class="flex justify-between"><span>10:00 PM Approx.</span> <span>Arrival in Lima and transfer to the initial pick-up point.</span></li>
									</ul>
								</div>
							</div>
						</div>

						{/* Costos */}
						<div class="mt-8 mb-10 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
							<div class="bg-brand-primary p-4">
								<h3 class="text-xl font-bold text-white text-center">TOUR TARIFF</h3>
							</div>
							<div class="p-6 text-center">
								<div class="text-3xl font-display font-bold text-brand-secondary mb-2">Contact Us</div>
								<p class="text-gray-600 font-medium">Please contact our team for current rates and availability.</p>
							</div>
						</div>
					</div>

					
				</div>

				{/* Info Column */}
				<div class="lg:col-span-1 space-y-8">
					<div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
						<div class="bg-brand-primary p-6">
							<h3 class="text-2xl font-display font-bold text-white flex items-center gap-2">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								Includes
							</h3>
						</div>
						<div class="p-6">
							<ul class="space-y-3 text-sm text-gray-700">
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Round-trip tourist transportation.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Bilingual Tour Guide.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Visit to Paracas Bay.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Visit to the Ballestas Islands by speedboat.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Observation of the Candelabro.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Observation of marine fauna and flora.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Visit to a Wine Winery in Ica.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Wine and Pisco tasting.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Visit to Huacachina Lagoon.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Dune buggy ride + Sandboarding.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Ballestas and Huacachina taxes.</li>
								<li class="flex items-start gap-2"><span class="text-brand-secondary font-bold">•</span> Assistance during the trip.</li>
							</ul>
						</div>
					</div>

					<div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
						<div class="bg-gray-100 p-6">
							<h3 class="text-2xl font-display font-bold text-gray-800 flex items-center gap-2">
								<svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
								Not Included
							</h3>
						</div>
						<div class="p-6">
							<ul class="space-y-3 text-sm text-gray-600">
								<li class="flex items-start gap-2"><span class="text-gray-400 font-bold">•</span> Breakfast.</li>
								<li class="flex items-start gap-2"><span class="text-gray-400 font-bold">•</span> Menu Lunch (starter + main course + drink).</li>
							</ul>
						</div>
					</div>

					{/* Pick Up Locations */}
					<div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mt-8">
						<div class="bg-blue-50 p-6 border-b border-blue-100">
							<h3 class="font-bold text-blue-900 mb-2">BOARDING POINT SERVICE</h3>
							<ul class="space-y-1 text-sm text-blue-800">
								<li><span class="font-bold">03:45 AM</span> PLAZA NORTE (Chifa Nuevo Mundo)</li>
								<li><span class="font-bold">04:10 AM</span> SAN ISIDRO (Javier Prado con Arequipa)</li>
								<li><span class="font-bold">04:20 AM</span> MIRAFLORES (Falabella)</li>
								<li><span class="font-bold">04:30 AM</span> MIRAFLORES (Larcomar)</li>
								<li><span class="font-bold">04:45 AM</span> PTE. PRÓCERES / ALIPIO</li>
							</ul>
						</div>
						<div class="bg-amber-50 p-6">
							<h3 class="font-bold text-amber-900 mb-2">HOTEL PICK-UP SERVICE</h3>
							<ul class="space-y-1 text-sm text-amber-800 mb-3">
								<li><span class="font-bold">04:10 AM</span> HOTELES CÉNTRICOS DE SAN ISIDRO</li>
								<li><span class="font-bold">04:25 AM</span> HOTELES CÉNTRICOS MIRAFLORES</li>
								<li><span class="font-bold">04:40 AM</span> HOTELES CÉNTRICOS BARRANCO</li>
							</ul>
							<p class="text-xs text-amber-700 italic">(Send hotel location to verify coverage)</p>
						</div>
					</div>

					<div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 mt-8">
						<h3 class="font-bold text-lg text-gray-900 mb-4">Book this tour</h3>
						<p class="text-gray-600 text-sm mb-6">Contact us via WhatsApp to confirm availability and reserve your spot.</p>
						<a href="https://wa.me/51967888138?text=Hello,%20I%20would%20like%20information%20about%20the%20Full%20Day%20Paracas%20Huacachina%20Pool%20Tour" target="_blank" class="block w-full text-center bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-3 px-4 rounded-xl transition-colors shadow-md">
							Book via WhatsApp
						</a>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
