---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.tsx';

// Cambia este valor a `true` si prefieres que se muestre una sola imagen en lugar del texto
const mostrarComoImagen = false; 
---

<Layout title="Métodos de Pago | Lima Inca Trips">
	<Navbar client:load solid={true} currentPath={Astro.url.pathname} />
	<main class="pt-20 min-h-screen bg-gray-50">
		<section class="pb-12 pt-4">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-10">
					<span class="text-brand-accent font-bold tracking-wider uppercase text-sm">Reserva tu Tour</span>
					<h1 class="mt-2 text-3xl md:text-4xl font-display font-bold text-brand-primary">Métodos de Pago</h1>
					<p class="mt-4 text-gray-600 max-w-2xl mx-auto text-lg">
						Trabajamos con total transparencia. Puedes realizar el pago de tus reservas a través de las siguientes cuentas bancarias oficiales a nombre de nuestra empresa.
					</p>
				</div>

				{mostrarComoImagen ? (
					<div class="text-center bg-white p-8 rounded-3xl shadow-xl border border-gray-100">
						<img src="/metodos-pago.png" alt="Métodos de Pago" class="mx-auto rounded-xl max-w-full" />
						<p class="text-sm text-gray-500 mt-4">
							Asegúrate de guardar tu imagen con el nombre exacto <strong>metodos-pago.png</strong> dentro de la carpeta <strong>public</strong>.
						</p>
					</div>
				) : (
					<div class="bg-white rounded-3xl shadow-lg overflow-hidden border border-gray-100 mb-8">
						<div class="p-6 md:p-8">
							<h2 class="text-xl font-bold text-brand-primary mb-6 border-b pb-3">Billeteras Digitales</h2>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
								<div class="flex items-center p-4 bg-purple-50 rounded-2xl border border-purple-100">
									<img src="/yape.png" alt="Yape" class="w-16 h-16 object-contain mr-4 drop-shadow-sm rounded-xl" />
									<div>
										<p class="text-gray-500 text-sm font-medium mb-0">Número Yape</p>
										<p class="text-lg font-bold text-gray-900 tracking-wider">952 977 904</p>
									</div>
								</div>
								<div class="flex items-center p-4 bg-cyan-50 rounded-2xl border border-cyan-100">
									<img src="/plin.png" alt="Plin" class="w-16 h-16 object-contain mr-4 drop-shadow-sm rounded-xl" />
									<div>
										<p class="text-gray-500 text-sm font-medium mb-0">Número Plin</p>
										<p class="text-lg font-bold text-gray-900 tracking-wider">952 977 904</p>
									</div>
								</div>
							</div>

							<h2 class="text-xl font-bold text-brand-primary mb-2 border-b pb-3">Cuentas Bancarias</h2>
							<p class="text-gray-600 text-sm mb-6 font-medium">
								Cuentas registradas a nombre de: <span class="text-brand-primary font-bold">CHACHAPOYAS TOURS - COM E.I.R.L.</span>
							</p>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
								{/* BCP Soles */}
								<div class="p-5 bg-gray-50 rounded-2xl border border-gray-200">
									<div class="flex items-center mb-3">
										<img src="/bcp.png" alt="BCP" class="w-8 h-8 object-contain mr-3 drop-shadow-sm rounded" />
										<h3 class="text-base font-bold text-gray-900">Cuenta Corriente (Soles)</h3>
									</div>
									<div class="space-y-2">
										<div>
											<p class="text-xs text-gray-500 uppercase">N° de Cuenta</p>
											<p class="text-base text-gray-900 font-medium">290 9930446 0 25</p>
										</div>
										<div>
											<p class="text-xs text-gray-500 uppercase">CCI</p>
											<p class="text-base text-gray-900 font-medium">002 290 009930446025 58</p>
										</div>
									</div>
								</div>

								{/* BCP Dólares */}
								<div class="p-5 bg-gray-50 rounded-2xl border border-gray-200">
									<div class="flex items-center mb-3">
										<img src="/bcp.png" alt="BCP" class="w-8 h-8 object-contain mr-3 drop-shadow-sm rounded" />
										<h3 class="text-base font-bold text-gray-900">Cuenta Corriente (Dólares)</h3>
									</div>
									<div class="space-y-2">
										<div>
											<p class="text-xs text-gray-500 uppercase">N° de Cuenta</p>
											<p class="text-base text-gray-900 font-medium">290 7328642 1 87</p>
										</div>
										<div>
											<p class="text-xs text-gray-500 uppercase">CCI</p>
											<p class="text-base text-gray-900 font-medium">002 290 007328642187 57</p>
										</div>
									</div>
								</div>
							</div>

							<h2 class="text-xl font-bold text-brand-primary mb-2 border-b pb-3">Otras Cuentas</h2>
							<p class="text-gray-600 text-sm mb-6 font-medium">
								A nombre de: <span class="text-brand-primary font-bold">Llender Mendoza Mas</span> (Company Manager)
							</p>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								{/* BBVA Soles */}
								<div class="p-5 bg-gray-50 rounded-2xl border border-gray-200">
									<div class="flex items-center mb-3">
										<img src="/bbva.png" alt="BBVA" class="w-8 h-8 object-contain mr-3 drop-shadow-sm rounded" />
										<h3 class="text-base font-bold text-gray-900">Cuenta de Ahorros (Soles)</h3>
									</div>
									<div class="space-y-2">
										<div>
											<p class="text-xs text-gray-500 uppercase">N° de Cuenta</p>
											<p class="text-base text-gray-900 font-medium">0011 0157 0200699984</p>
										</div>
										<div>
											<p class="text-xs text-gray-500 uppercase">CCI</p>
											<p class="text-base text-gray-900 font-medium">011 157 000200699984 57</p>
										</div>
									</div>
								</div>

								{/* Banco de la Nación Soles */}
								<div class="p-5 bg-gray-50 rounded-2xl border border-gray-200">
									<div class="flex items-center mb-3">
										<img src="/bn.png" alt="Banco de la Nación" class="w-8 h-8 object-contain mr-3 drop-shadow-sm rounded" />
										<h3 class="text-base font-bold text-gray-900">Cuenta de Ahorros (Soles)</h3>
									</div>
									<div class="space-y-2">
										<div>
											<p class="text-xs text-gray-500 uppercase">N° de Cuenta</p>
											<p class="text-base text-gray-900 font-medium">04-138-067667</p>
										</div>
										<div>
											<p class="text-xs text-gray-500 uppercase">CCI</p>
											<p class="text-base text-gray-900 font-medium">018-265-004138067667-90</p>
										</div>
									</div>
								</div>
							</div>
							
						</div>
						<div class="bg-brand-primary p-5 md:p-6 text-center text-white">
							<p class="font-medium text-sm">
								Una vez realizado el depósito, envíanos la foto del comprobante a nuestro WhatsApp para procesar tu reserva.
							</p>
							<a href="https://wa.me/51936976776?text=Hola,%20acabo%20de%20realizar%20el%20pago%20de%20mi%20reserva.%20Adjunto%20el%20voucher." target="_blank" class="inline-flex items-center mt-4 bg-white text-brand-primary font-bold py-2 px-6 rounded-full hover:bg-gray-100 transition-colors text-sm">
								<svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
								Enviar Voucher por WhatsApp
							</a>
						</div>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>
