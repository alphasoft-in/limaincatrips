---
import SocialIcons from './SocialIcons.tsx';

const currentYear = new Date().getFullYear();
const isEn = Astro.url.pathname.startsWith('/en');
const pagosLink = isEn ? '/en/payments' : '/pagos';
const pagosText = isEn ? 'Payment Methods' : 'Métodos de Pago';
---

<footer class="bg-brand-primary text-white pt-16 pb-8 border-t-4 border-brand-secondary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      {/* Brand & About */}
      <div class="space-y-4">
        <a href="/" class="block mb-6">
          <img 
            src="/logo-trimmed.png" 
            alt="Lima Inca TRIPS" 
            class="h-14 w-auto object-contain brightness-0 invert" 
          />
        </a>
        <p class="text-gray-300 text-sm leading-relaxed">
          Descubre la magia del Perú con Lima Inka Trip. Ofrecemos las mejores experiencias y tours guiados para que tu viaje sea inolvidable.
        </p>
        <SocialIcons client:visible />
      </div>

      {/* Quick Links */}
      <div>
        <h3 class="text-lg font-bold text-white tracking-wider mb-6 flex items-center">
          ENLACES RÁPIDOS
          <span class="w-12 h-1 bg-brand-secondary ml-3 rounded-full"></span>
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Inicio
            </a>
          </li>
          <li>
            <a href="/destinations" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Destinos
            </a>
          </li>
          <li>
            <a href="/tours" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Tours
            </a>
          </li>
          <li>
            <a href="/about" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Nosotros
            </a>
          </li>
          <li>
            <a href="/contact" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Contacto
            </a>
          </li>
        </ul>
      </div>

      {/* Top Tours */}
      <div>
        <h3 class="text-lg font-bold text-white tracking-wider mb-6 flex items-center">
          TOURS DESTACADOS
          <span class="w-12 h-1 bg-brand-secondary ml-3 rounded-full"></span>
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/ica/paracas-huacachina-2d-1n" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Paracas y Huacachina
            </a>
          </li>
          <li>
            <a href="/ica/nazca-sobrevuelo-half-day" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Sobrevuelo Líneas de Nazca
            </a>
          </li>
          <li>
            <a href="/selva-central/selva-central-4d-3n" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              Aventura Selva Central
            </a>
          </li>
          <li>
            <a href="/lima/lima-miraflores-city-tour" class="text-gray-300 hover:text-brand-secondary hover:pl-2 transition-all duration-300 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              City Tour Lima
            </a>
          </li>
        </ul>
      </div>

      {/* Contact Info */}
      <div>
        <h3 class="text-lg font-bold text-white tracking-wider mb-6 flex items-center">
          CONTÁCTANOS
          <span class="w-12 h-1 bg-brand-secondary ml-3 rounded-full"></span>
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 text-brand-secondary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="text-gray-300 text-sm">
              jr Ortiz Arrieta 508 - Chachapoyas<br/>
              Jr. Morro Solar 2252 - Santiago de Surco
            </span>
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 mr-3 text-brand-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span class="text-gray-300 text-sm">+51 936 976 776</span>
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 mr-3 text-brand-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:reservas@limainkatrip.com" class="text-gray-300 text-sm hover:text-brand-secondary transition-colors">reservas@limainkatrip.com</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* Copyright */}
  <div class="border-t border-gray-800 pt-8 mt-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-400 text-sm text-center md:text-left mb-4 md:mb-0">
        &copy; {currentYear} Lima Inka Trip - RUC: 20607493031. Todos los derechos reservados.
      </p>
      <div class="flex space-x-6 text-sm">
        <a href={pagosLink} class="text-gray-400 hover:text-brand-secondary transition-colors font-medium">{pagosText}</a>
        <a href="#" class="text-gray-400 hover:text-brand-secondary transition-colors">Términos y Condiciones</a>
        <a href="#" class="text-gray-400 hover:text-brand-secondary transition-colors">Política de Privacidad</a>
      </div>
    </div>
  </div>
</footer>
